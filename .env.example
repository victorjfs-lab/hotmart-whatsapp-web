# Servidor
PORT=3000
BASE_URL=http://localhost:3000

# Segurança do webhook da Hotmart.
# Configure o mesmo token no painel da Hotmart e na Hotmart.
HOTMART_WEBHOOK_SECRET=troque-este-token

# Eventos aceitos separados por virgula.
HOTMART_ALLOWED_EVENTS=PURCHASE_APPROVED,PURCHASE_COMPLETE

# Envio pelo WhatsApp Web. A sessão fica salva em data/whatsapp-session.
WHATSAPP_PROVIDER=web

# Uma mensagem por linha. Variáveis disponíveis:
# {{nome}}, {{produto}}, {{email}}, {{transacao}}
WHATSAPP_TEXT_MESSAGES=Oi, {{nome}}! Sua compra de {{produto}} foi confirmada.

# Opcional: proteja a API do painel em produção.
# Quando preenchido, abra /?token=... e chame APIs com ?token=...
DASHBOARD_TOKEN=
